# Vercel 環境變數（Settings -> Environment Variables），給 api/intervals-zwo.js 用。
# 不要把真正的值提交進 git —— 這個檔案只列出變數名稱，複製一份改成 .env.local
# 供本機 `vercel dev` 測試用（.env.local 已被視為機密，不應該提交）。

# intervals.icu 個人設定頁看得到的 Athlete ID（含開頭的 "i"，例如 i123456）
INTERVALS_ICU_ATHLETE_ID=

# intervals.icu -> Settings -> Developer Settings 產生的 API Key
INTERVALS_ICU_API_KEY=
