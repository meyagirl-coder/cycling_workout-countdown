<workout_file>
    <author>Test Author</author>
    <name>Basic SST Session</name>
    <description>Simple warmup, steady state, cooldown workout for parser testing.</description>
    <sportType>bike</sportType>
    <tags/>
    <workout>
        <Warmup Duration="600" PowerLow="0.5" PowerHigh="0.7"/>
        <SteadyState Duration="720" Power="0.88" Cadence="90"/>
        <Cooldown Duration="300" PowerLow="0.7" PowerHigh="0.5"/>
    </workout>
</workout_file>
