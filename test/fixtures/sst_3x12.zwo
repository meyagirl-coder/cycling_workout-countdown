<workout_file>
    <author>Test Author</author>
    <name>SST 3x12</name>
    <description>Three 12-minute sweet spot intervals with recovery between reps, matching the Phase 1 spec example.</description>
    <sportType>bike</sportType>
    <tags/>
    <workout>
        <Warmup Duration="600" PowerLow="0.5" PowerHigh="0.7"/>
        <SteadyState Duration="720" Power="0.88" Cadence="90"/>
        <FreeRide Duration="300"/>
        <SteadyState Duration="720" Power="0.88" Cadence="90"/>
        <FreeRide Duration="300"/>
        <SteadyState Duration="720" Power="0.88" Cadence="90"/>
        <Cooldown Duration="600" PowerLow="0.7" PowerHigh="0.5"/>
    </workout>
</workout_file>
